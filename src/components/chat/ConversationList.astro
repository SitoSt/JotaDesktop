---
// ConversationList: scrollable wrapper for ConversationItem elements.
// JS clears and populates this container after fetching conversations.
---

<div id="conversation-list" class="conversation-list">
    <div class="conversation-list__loading">Cargando...</div>
</div>

<style>
    .conversation-list {
        flex: 1;
        overflow-y: auto;
        padding: 8px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .conversation-list__loading,
    .conversation-list__empty,
    .conversation-list__error {
        padding: 20px;
        text-align: center;
        color: #888;
        font-size: 0.88em;
    }

    .conversation-list__error {
        color: #c75555;
    }
</style>
