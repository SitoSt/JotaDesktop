---
// TypingIndicator: animated dots shown while waiting for a response.
// isModelLoading switches to a blue-tinted "loading model weights" variant.
// This component can be used as a reference; JS creates clones imperatively.

interface Props {
    isModelLoading?: boolean;
}

const { isModelLoading = false } = Astro.props;
---

<div
    class:list={[
        "typing-indicator",
        { "typing-indicator--loading": isModelLoading },
    ]}
>
    <span class="pulse-dot"></span>
    <span class="pulse-dot"></span>
    <span class="pulse-dot"></span>
    {
        isModelLoading && (
            <span class="typing-indicator__label">
                Cargando pesos del modelo en memoria...
            </span>
        )
    }
</div>

<style>
    .typing-indicator {
        display: flex;
        align-items: center;
        gap: 5px;
        padding: 12px 16px;
        border-radius: 10px;
        background: #333;
        align-self: flex-start;
        max-width: 80%;
    }

    .pulse-dot {
        display: inline-block;
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #888;
        animation: pulse 1.2s infinite ease-in-out;
        flex-shrink: 0;
    }

    .pulse-dot:nth-child(2) {
        animation-delay: 0.2s;
    }
    .pulse-dot:nth-child(3) {
        animation-delay: 0.4s;
    }

    .typing-indicator--loading .pulse-dot {
        background: #007acc;
    }

    .typing-indicator__label {
        font-size: 0.82em;
        color: #7ab8e8;
        font-style: italic;
        margin-left: 4px;
    }

    @keyframes pulse {
        0%,
        80%,
        100% {
            transform: scale(0.8);
            opacity: 0.5;
        }
        40% {
            transform: scale(1.2);
            opacity: 1;
        }
    }
</style>
