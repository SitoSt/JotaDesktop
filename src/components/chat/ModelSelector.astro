---
// ModelSelector: dropdown for choosing the active inference model.
// Options are populated by JS after getModels() resolves.
---

<div class="model-selector">
    <svg
        class="model-selector__icon"
        xmlns="http://www.w3.org/2000/svg"
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
    >
        <ellipse cx="12" cy="5" rx="9" ry="3"></ellipse>
        <path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"></path>
        <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path>
    </svg>
    <label for="model-selector" class="model-selector__label">Modelo</label>
    <select id="model-selector" class="model-selector__select" disabled>
        <option value="">Cargando...</option>
    </select>
</div>

<style>
    .model-selector {
        display: flex;
        align-items: center;
        gap: 7px;
    }

    .model-selector__icon {
        color: #007acc;
        flex-shrink: 0;
    }

    .model-selector__label {
        font-size: 0.75em;
        font-weight: 500;
        color: #888;
        white-space: nowrap;
        letter-spacing: 0.03em;
    }

    .model-selector__select {
        background: #1e1e1e;
        color: #e0e0e0;
        border: 1px solid #444;
        border-radius: 6px;
        padding: 5px 10px 5px 8px;
        font-size: 0.8em;
        cursor: pointer;
        transition: border-color 0.2s;
        max-width: 220px;
    }

    .model-selector__select:focus {
        outline: none;
        border-color: #007acc;
    }

    .model-selector__select:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }
</style>
