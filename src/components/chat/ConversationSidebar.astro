---
import ConversationList from "./ConversationList.astro";
import Button from "../ui/Button.astro";
---

<div class="conversation-sidebar" id="conversation-sidebar">
    <div class="sidebar-header">
        <h2 class="sidebar-header__title">Historial</h2>
        <Button
            id="new-chat-btn"
            label="Nueva Charla"
            variant="primary"
            fullWidth
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
        </Button>
    </div>

    <ConversationList />
</div>

<script>
    import { JotaApiService, type Conversation } from "../../services/api";

    // ── Bootstrap: read config injected by ChatContainer ──────────────────────
    const chatContainer = document.querySelector(
        ".chat-container",
    ) as HTMLElement | null;
    const apiUrl = chatContainer?.dataset.apiUrl ?? "";
    const clientKey = chatContainer?.dataset.clientKey ?? "";
    const userId =
        localStorage.getItem("jota_user_id") ||
        chatContainer?.dataset.initialUserId ||
        "";

    const api = new JotaApiService(apiUrl, clientKey);

    // ── DOM refs ──────────────────────────────────────────────────────────────
    const listEl = document.getElementById(
        "conversation-list",
    ) as HTMLDivElement;
    const newChatBtn = document.getElementById(
        "new-chat-btn",
    ) as HTMLButtonElement;

    let activeConversationId: string | null = null;
    let isLoaded = false;

    // ── Load & render conversations ───────────────────────────────────────────
    async function loadConversations() {
        if (!userId || !apiUrl) {
            listEl.innerHTML =
                '<div class="conversation-list__error">Sin configuración</div>';
            return;
        }

        listEl.innerHTML =
            '<div class="conversation-list__loading">Cargando...</div>';

        const conversations = await api.conversations.getConversations(
            userId,
            50,
        );

        if (conversations.length === 0) {
            listEl.innerHTML =
                '<div class="conversation-list__empty">No hay conversaciones</div>';
            isLoaded = true;
            return;
        }

        renderConversations(conversations);
    }

    function renderConversations(conversations: Conversation[]) {
        listEl.innerHTML = "";
        isLoaded = true;

        for (const conv of conversations) {
            const item = document.createElement("div");
            item.className =
                "conversation-item" +
                (conv.id === activeConversationId ? " active" : "");
            item.dataset.id = conv.id;
            item.role = "button";
            item.tabIndex = 0;

            const date = new Date(conv.created_at).toLocaleDateString(
                undefined,
                {
                    month: "short",
                    day: "numeric",
                },
            );

            const modelBadge = conv.model_id
                ? `<span class="conv-model-badge">${conv.model_id}</span>`
                : "";

            item.innerHTML = `
                <svg class="conversation-item__icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                    viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                </svg>
                <div class="conversation-item__content">
                    <span class="conversation-item__title">${conv.title ?? "Nueva conversación"}</span>
                    <div class="conv-meta">
                        <span class="conversation-item__date">${date}</span>
                        ${modelBadge}
                    </div>
                </div>`;

            item.addEventListener("click", () => selectConversation(conv.id));
            item.addEventListener("keydown", (e) => {
                if (e.key === "Enter" || e.key === " ")
                    selectConversation(conv.id);
            });

            listEl.appendChild(item);
        }
    }

    function selectConversation(id: string) {
        if (id === activeConversationId) return;
        document.dispatchEvent(
            new CustomEvent("jota:loadConversation", {
                detail: { conversationId: id },
            }),
        );
    }

    function updateActiveItem(id: string | null) {
        if (!isLoaded) return;
        listEl
            .querySelectorAll<HTMLDivElement>(".conversation-item")
            .forEach((item) => {
                item.classList.toggle("active", item.dataset.id === id);
            });
    }

    // ── Events ────────────────────────────────────────────────────────────────
    newChatBtn?.addEventListener("click", () => {
        document.dispatchEvent(
            new CustomEvent("jota:loadConversation", {
                detail: { conversationId: null },
            }),
        );
    });

    document.addEventListener("jota:conversationChanged", (e: any) => {
        activeConversationId = e.detail.conversationId ?? null;
        updateActiveItem(activeConversationId);
    });

    document.addEventListener("jota:refreshConversations", () =>
        loadConversations(),
    );

    // ── Init (slight delay to let ChatContainer write user info first) ─────────
    setTimeout(loadConversations, 120);
</script>

<style>
    .conversation-sidebar {
        width: 260px;
        background: #252526;
        border-right: 1px solid #333;
        display: flex;
        flex-direction: column;
        height: 100%;
        overflow: hidden;
        flex-shrink: 0;
    }

    .sidebar-header {
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        border-bottom: 1px solid #333;
    }

    .sidebar-header__title {
        margin: 0;
        font-size: 1.05em;
        font-weight: 600;
        color: #e0e0e0;
    }

    /* Conversation item styles (rendered via JS) */
    :global(.conversation-item) {
        padding: 11px 14px;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 12px;
        transition: all 0.18s ease;
        border: 1px solid transparent;
        outline: none;
    }

    :global(.conversation-item:hover) {
        background: #2d2d30;
    }
    :global(.conversation-item:focus-visible) {
        border-color: #007acc;
    }

    :global(.conversation-item.active) {
        background: #37373d;
        border-color: #454545;
    }

    :global(.conversation-item__icon) {
        color: #888;
        flex-shrink: 0;
    }
    :global(.conversation-item.active .conversation-item__icon) {
        color: #007acc;
    }

    :global(.conversation-item__content) {
        display: flex;
        flex-direction: column;
        overflow: hidden;
        flex: 1;
        gap: 3px;
    }

    :global(.conversation-item__title) {
        font-size: 0.88em;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        color: #e0e0e0;
        font-weight: 500;
    }

    :global(.conversation-item.active .conversation-item__title) {
        color: #fff;
    }

    :global(.conv-meta) {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    :global(.conversation-item__date) {
        font-size: 0.72em;
        color: #858585;
    }

    :global(.conv-model-badge) {
        font-size: 0.65em;
        color: #007acc;
        background: #1a2e40;
        border-radius: 3px;
        padding: 1px 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 90px;
    }
</style>
