---
// Connection established strictly through client-side scripting to prevent Astro dev hydration issues on SSR
---

<div class="conversation-sidebar" id="conversation-sidebar">
    <div class="sidebar-header">
        <h2>Historial</h2>
        <button id="new-chat-btn" class="new-chat-btn">
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><line x1="12" y1="5" x2="12" y2="19"></line><line
                    x1="5"
                    y1="12"
                    x2="19"
                    y2="12"></line></svg
            >
            Nueva Charla
        </button>
    </div>
    <div class="conversation-list" id="conversation-list">
        <!-- Rendered via JS -->
        <div class="loading-state">Cargando...</div>
    </div>
</div>

<script>
    import { apiService } from "../../services/jotaApiService";

    // Obtain configuration
    const container = document.querySelector(".chat-container") as HTMLElement;
    const initialUserId = container?.dataset?.initialUserId || "";
    let userId = initialUserId || localStorage.getItem("jota_user_id");

    const listContainer = document.getElementById(
        "conversation-list",
    ) as HTMLDivElement;
    const newChatBtn = document.getElementById(
        "new-chat-btn",
    ) as HTMLButtonElement;
    let currentConversationId: string | null = null;
    let isLoaded = false;

    // Listen to custom event when a conversation is activated (from ChatContainer)
    document.addEventListener("jota:conversationChanged", (e: any) => {
        currentConversationId = e.detail.conversationId;
        updateActiveState();
    });

    async function loadConversations() {
        if (!userId) return;

        try {
            const conversations = await apiService.getConversations(userId, 50);
            renderConversations(conversations);
            isLoaded = true;
        } catch (e) {
            console.error("Failed to load sidebar", e);
            listContainer.innerHTML =
                '<div class="error-state">Error al cargar historial</div>';
        }
    }

    function renderConversations(conversations: any[]) {
        if (!conversations || conversations.length === 0) {
            listContainer.innerHTML =
                '<div class="empty-state">No hay conversaciones pasadas</div>';
            return;
        }

        listContainer.innerHTML = "";
        conversations.forEach((conv) => {
            const div = document.createElement("div");
            div.className = "conversation-item";
            if (conv.id == currentConversationId) div.classList.add("active");
            div.dataset.id = conv.id;

            // Format title/date
            const dateObj = new Date(conv.created_at);
            const dateStr = dateObj.toLocaleDateString(undefined, {
                month: "short",
                day: "numeric",
                hour: "2-digit",
                minute: "2-digit",
            });

            const titleSpan = document.createElement("span");
            titleSpan.className = "conv-title";
            titleSpan.textContent = conv.title || "Nueva conversación";

            const dateSpan = document.createElement("span");
            dateSpan.className = "conv-date";
            dateSpan.textContent = dateStr;

            div.appendChild(titleSpan);
            div.appendChild(dateSpan);

            div.addEventListener("click", () => {
                if (currentConversationId == conv.id) return; // Already active

                // Dispatch event to ChatContainer to load this conversation
                document.dispatchEvent(
                    new CustomEvent("jota:loadConversation", {
                        detail: { conversationId: conv.id },
                    }),
                );
            });

            listContainer.appendChild(div);
        });
    }

    function updateActiveState() {
        if (!isLoaded) return;
        const items = listContainer.querySelectorAll(".conversation-item");
        items.forEach((item) => {
            if ((item as HTMLElement).dataset.id == currentConversationId) {
                item.classList.add("active");
            } else {
                item.classList.remove("active");
            }
        });
    }

    newChatBtn.addEventListener("click", () => {
        if (!currentConversationId) return; // Already starting a new one usually

        // Tells ChatContainer to drop current context and start fresh
        document.dispatchEvent(
            new CustomEvent("jota:loadConversation", {
                detail: { conversationId: null },
            }),
        );
    });

    // Initial load
    // Timeout added just to let main script setup first and prevent race conditions with JotaService init
    setTimeout(loadConversations, 100);

    // Refresh list when a new message is first sent in a new conversation?
    // Listen to "jota:refreshConversations"
    document.addEventListener("jota:refreshConversations", () => {
        loadConversations();
    });
</script>

<style>
    .conversation-sidebar {
        width: 260px;
        background: #252526;
        border-right: 1px solid #333;
        display: flex;
        flex-direction: column;
        height: 100%;
        overflow: hidden;
    }

    .sidebar-header {
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        border-bottom: 1px solid #333;
    }

    .sidebar-header h2 {
        margin: 0;
        font-size: 1.1em;
        font-weight: 500;
        color: #e0e0e0;
    }

    .new-chat-btn {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 10px;
        background: #007acc;
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 500;
        transition: background 0.2s;
    }

    .new-chat-btn:hover {
        background: #0062a3;
    }

    .conversation-list {
        flex: 1;
        overflow-y: auto;
        padding: 8px;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .conversation-item {
        padding: 12px;
        border-radius: 6px;
        cursor: pointer;
        display: flex;
        flex-direction: column;
        gap: 4px;
        transition: background 0.2s;
    }

    .conversation-item:hover {
        background: #333;
    }

    .conversation-item.active {
        background: #37373d;
        border-left: 3px solid #007acc;
    }

    .conv-title {
        font-size: 0.9em;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        color: #eee;
    }

    .conv-date {
        font-size: 0.75em;
        color: #888;
    }

    .loading-state,
    .empty-state,
    .error-state {
        padding: 20px;
        text-align: center;
        color: #888;
        font-size: 0.9em;
    }
</style>
